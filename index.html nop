    ${noticeHTML()}
    <div class="streak">
      <div class="stat"><div class="n">${ITEMS.length}</div><div class="l">Einträge</div></div>
      <div class="stat"><div class="n">${S.have.size}</div><div class="l">Aufnahmen</div></div>
      <div class="stat"><div class="n">${missing}</div><div class="l">fehlen noch</div></div>
    </div>

    <div class="panel">
      <div class="eyebrow">Neuer Eintrag</div>
      <label class="lb">Kapitel und Lektion</label>
      <select class="field" id="n-l">${allLessons().filter(x=>!x.l.rev).map(x=>
