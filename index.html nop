    <input class="field" id="aq" placeholder="Suchen …" value="${esc(S.search)}">
    ${COURSE.map((ch,ci)=>{
      const rows = ITEMS.filter(i=>i.ci===ci && (!S.search || norm(i.de+i.tr).includes(norm(S.search))));
      if(!rows.length) return "";
      return `<h2>${ci+1}. ${esc(ch.t)}</h2><div class="list">${rows.map(i=>{
        const rec = S.recId===i.id && S.recStore==="audio";
        return `<div class="item">
          <span class="dot ${S.have.has(i.id)?"on":""}"></span>
          <div class="txt"><div class="de">${esc(i.de)}</div><div class="say">${esc(i.tr)}</div></div>
          ${S.have.has(i.id)?`<button class="icon" data-p="${i.id}">▶</button>`:""}
          <button class="icon ${rec?"rec":""}" data-r="${i.id}">${rec?"■":"●"}</button>
          <button class="icon" data-e="${i.id}">✎</button>
        </div>`;
      }).join("")}</div>`;
