        <button class="icon ${S.playing===i.id?"on":""}" data-p="${i.id}" aria-label="Anhören">▶</button>
        <button class="icon ${S.fav[i.id]?"on":""}" data-f="${i.id}" aria-label="Lieblingswort">★</button>
        <button class="icon ${S.hard[i.id]?"on":""}" data-h="${i.id}" aria-label="Schwierig">!</button>
      </div>`).join("")}</div>`
      : `<div class="panel sub">Nichts gefunden.</div>`}
    <p class="sub" style="margin-top:14px">Punkt links heißt: Aufnahme vorhanden.</p>`;
  const inp=$("#q");
  inp.oninput = e => { S.search=e.target.value; const p=e.target.selectionStart; repaint(); const n=$("#q"); n.focus(); n.setSelectionRange(p,p); };
  $$("[data-ch]").forEach(b=>b.onclick=()=>{S.listCh=+b.dataset.ch;repaint();});
  $$("[data-p]").forEach(b=>b.onclick=()=>play(b.dataset.p));
  $$("[data-f]").forEach(b=>b.onclick=()=>{S.fav[b.dataset.f]=!S.fav[b.dataset.f];save();repaint();});
  $$("[data-h]").forEach(b=>b.onclick=()=>{S.hard[b.dataset.h]=!S.hard[b.dataset.h];save();repaint();});
}

/* ========================= Lektion bauen ========================= */
function distract(item, n=3){
  const same = ITEMS.filter(i=>i.id!==item.id && i.kind===item.kind && i.ci===item.ci);
  const pool = (same.length>=n?same:ITEMS.filter(i=>i.id!==item.id));
  return pool.sort(()=>Math.random()-.5).slice(0,n);
}
function quizStep(item, kind){
  if(kind==="type" && item.kind==="w") return {k:"type",item};
  if(kind==="hear") return {k:"mc",item,dir:"hear",opts:shuffle([item,...distract(item)])};
  const dir = Math.random()<.5 ? "de2tr":"tr2de";
  return {k:"mc",item,dir,opts:shuffle([item,...distract(item)])};
}
const shuffle = a => a.slice().sort(()=>Math.random()-.5);

function startLesson(ci,li){
  const l = COURSE[ci].ls[li];
  const items = lessonOf(ci,li);
  const steps=[];
  if(l.dlg){
    steps.push({k:"dlg",ci,li});
    items.forEach(it=>steps.push({k:"teach",item:it}));
    shuffle(items).slice(0,5).forEach(it=>steps.push(quizStep(it)));
  } else if(l.rev){
    const prev = ITEMS.filter(i=>i.ci===ci && i.li<li);
    const mix = shuffle([...dueItems(), ...prev]).filter((v,i,a)=>a.findIndex(x=>x.id===v.id)===i).slice(0,12);
    if(!mix.length){ toast("Erst ein paar Lektionen lernen, dann gibt es hier etwas zu wiederholen."); return; }
    mix.forEach(it=>steps.push(quizStep(it, it.kind==="w"&&Math.random()<.35?"type":"")));
  } else {
    items.forEach(it=>steps.push({k:"teach",item:it}));
    shuffle(items).forEach(it=>steps.push(quizStep(it)));
    shuffle(items).slice(0,3).forEach(it=>steps.push(quizStep(it,it.kind==="w"?"type":"")));
    const old = shuffle(dueItems().filter(i=>!items.some(x=>x.id===i.id))).slice(0,3);
    old.forEach(it=>steps.push(quizStep(it)));
  }
  RUN={steps,i:0,right:0,wrong:0,ci,li,lesson:true,answered:false,picked:null};
  window.scrollTo(0,0); renderRun();
}
function startReview(){
  const d=shuffle(dueItems()).slice(0,15);
  if(!d.length){ toast("Gerade ist nichts fällig."); return; }
  runFrom(d,"mix");
}
function runFrom(items, mode){
  if(!items.length){ toast("Dafür gibt es noch keine Wörter."); return; }
  const steps=[];
  items.forEach(it=>{
    if(mode==="teach") steps.push({k:"teach",item:it});
    else if(mode==="hear") steps.push(quizStep(it,"hear"));
    else if(mode==="type") steps.push(quizStep(it,"type"));
    else steps.push(quizStep(it));
  });
  RUN={steps,i:0,right:0,wrong:0,lesson:false,answered:false,picked:null};
  window.scrollTo(0,0); renderRun();
}
function endRun(){
  if(RUN && RUN.lesson){
    S.done[lessonKey(RUN.ci,RUN.li)] = 1;
    addXP(20 + RUN.right*5);
  } else if(RUN){ addXP(RUN.right*5); }
  const right=RUN?RUN.right:0, total=RUN?(RUN.right+RUN.wrong):0;
  const cheer = CHEERS[Math.floor(Math.random()*CHEERS.length)];
  RUN=null; save();
  $("#app").innerHTML = `
    <div class="eyebrow">Fertig</div>
    <h1>${cheer}</h1>
    <div class="streak">
      <div class="stat"><div class="n">${total?Math.round(right/total*100):100}%</div><div class="l">richtig</div></div>
      <div class="stat"><div class="n">${S.xpToday}</div><div class="l">XP heute</div></div>
      <div class="stat"><div class="n">${S.streak}</div><div class="l">Tage in Folge</div></div>
    </div>
    <button class="btn" id="more">Weiter lernen</button>
    <button class="btn quiet" id="home">Zurück zur Übersicht</button>`;
  $("#more").onclick=()=>{ const n=nextLesson(); startLesson(n.ci,n.li); };
  $("#home").onclick=()=>{ S.view="heute"; repaint(); paintTabs(); };
  paintTabs();
}

/* ========================= Lektion anzeigen ========================= */
function renderRun(){
  const st = RUN.steps[RUN.i];
  if(!st) return endRun();
  const pct = Math.round(RUN.i/RUN.steps.length*100);
  const head = `<div class="progress-top">
      <button class="x" id="quit" aria-label="Beenden">✕</button>
      <div class="bar"><i style="width:${pct}%"></i></div>
      <span class="mut" style="font-family:var(--mono);font-size:12px">${RUN.i+1}/${RUN.steps.length}</span>
    </div>${noticeHTML()}`;
  const box = {teach:stepTeach, mc:stepMC, type:stepType, dlg:stepDlg}[st.k](st);
  $("#app").innerHTML = head + box.html;
  $("#quit").onclick = ()=>{ RUN=null; S.view= S.view==="admin"?"kurs":S.view; repaint(); paintTabs(); };
  box.wire();
}
const nextStep = ()=>{ RUN.i++; RUN.answered=false; RUN.picked=null; window.scrollTo(0,0); renderRun(); };

function stepTeach(st){
  const i=st.item, has=S.have.has(i.id), mine=S.mine.has(i.id), rec=S.recId===i.id&&S.recStore==="mine";
  return {
    html:`<div class="stage">
      <div class="eyebrow">Hören · Nachsprechen · Wiederholen</div>
      <div class="de">${esc(i.de)}</div>
      <div class="say ${i.tr.length>16?"sm":""}">${esc(i.tr)}</div>
      <div class="audio-row">
        <button class="abtn" data-play="1" ${has?"":"disabled"}>▶ Anhören</button>
        <button class="abtn" data-slow="1" ${has?"":"disabled"}>◐ Langsam</button>
      </div>
      <div class="audio-row">
        <button class="abtn ${rec?"live":""}" data-rec="1">${rec?"■ Stopp":"● Nachsprechen"}</button>
        <button class="abtn" data-mine="1" ${mine?"":"disabled"}>▶ Meine Aufnahme</button>
      </div>
      ${has?"":`<div class="hint">Für dieses Wort fehlt noch die Aufnahme. Im Adminbereich lässt sie sich einsprechen.</div>`}
      <div class="hint">Sprich es dreimal laut nach: langsam, normal, dann ohne Hinsehen.</div>
    </div>
    <div class="btn-row"><button class="btn" id="ok">Weiter</button></div>
    <div class="btn-row">
      <button class="btn ghost" id="fav">${S.fav[i.id]?"★ gespeichert":"☆ Lieblingswort"}</button>
      <button class="btn ghost" id="hard">${S.hard[i.id]?"! schwierig":"Als schwierig"}</button>
    </div>`,
    wire(){
      $("[data-play]").onclick=()=>play(i.id);
      $("[data-slow]").onclick=()=>play(i.id,.6);
      $("[data-rec]").onclick=()=>S.recId?stopRec():startRec(i.id,"mine");
      $("[data-mine]").onclick=()=>play(i.id,1,"mine");
      $("#fav").onclick=()=>{S.fav[i.id]=!S.fav[i.id];save();renderRun();};
      $("#hard").onclick=()=>{S.hard[i.id]=!S.hard[i.id];save();renderRun();};
      $("#ok").onclick=()=>{ touch(i.id); addXP(2); nextStep(); };
    }};
}

function stepMC(st){
  const i=st.item, opts=st.opts, ask = st.dir==="hear" ? "Was hörst du?" : (st.dir==="de2tr"?"Wie sagt man das?":"Was heißt das?");
  const prompt = st.dir==="hear" ? `<button class="abtn" id="hear">▶ Nochmal hören</button>`
    : st.dir==="de2tr" ? `<div class="de">${esc(i.de)}</div>` : `<div class="say ${i.tr.length>16?"sm":""}">${esc(i.tr)}</div>`;
  const front = o => st.dir==="tr2de" ? esc(o.de) : `<span class="k">${esc(o.tr)}</span>`;
  const back  = o => st.dir==="tr2de" ? `<span class="k">${esc(o.tr)}</span>` : `<span class="mut">${esc(o.de)}</span>`;
  return {
    html:`<div class="stage"><div class="eyebrow">${ask}</div>${prompt}</div>
      <div class="opts">${opts.map(o=>{
        let cls="";
        if(RUN.answered) cls = o.id===i.id ? "right" : (o.id===RUN.picked?"wrong":"");
        return `<button class="opt ${cls}" data-o="${esc(o.id)}" ${RUN.answered?"disabled":""}>
          ${front(o)}${RUN.answered?back(o):""}</button>`;
      }).join("")}</div>
      ${RUN.answered?`<div class="btn-row"><button class="btn" id="next">Weiter</button></div>`:""}`,
    wire(){
      if(st.dir==="hear"){ const h=$("#hear"); if(h) h.onclick=()=>play(i.id); if(!RUN.answered && S.have.has(i.id)) play(i.id); }
      $$("[data-o]").forEach(b=>b.onclick=()=>{
        if(RUN.answered) return;
        RUN.picked=b.dataset.o; RUN.answered=true;
        const ok = RUN.picked===i.id;
        ok?RUN.right++:RUN.wrong++; grade(i.id,ok);
        if(ok) addXP(10); else S.hard[i.id]=1;
        renderRun();
      });
      const n=$("#next"); if(n) n.onclick=nextStep;
    }};
}

function stepType(st){
  const i=st.item;
  return {
    html:`<div class="stage">
        <div class="eyebrow">Schreib die Aussprache</div>
        <div class="de">${esc(i.de)}</div>
        ${S.have.has(i.id)?`<div class="audio-row"><button class="abtn" id="p">▶ Anhören</button></div>`:""}
      </div>
      <div style="margin-top:14px"><input class="answer" id="a" autocapitalize="off" autocomplete="off" spellcheck="false" placeholder="…"></div>
      <div id="v"></div>
      <div class="btn-row"><button class="btn" id="ck">Prüfen</button></div>`,
    wire(){
      const p=$("#p"); if(p) p.onclick=()=>play(i.id);
      const inp=$("#a"); setTimeout(()=>inp.focus(),60);
      const check=()=>{
        if(RUN.answered) return nextStep();
        const ok = norm(inp.value)===norm(i.tr);
        RUN.answered=true; ok?RUN.right++:RUN.wrong++; grade(i.id,ok);
        if(ok) addXP(12); else S.hard[i.id]=1;
        $("#v").innerHTML = ok
          ? `<div class="verdict ok">Richtig. <b>${esc(i.tr)}</b></div>`
          : `<div class="verdict no">Fast. Richtig ist <b>${esc(i.tr)}</b></div>`;
        $("#ck").textContent="Weiter"; inp.blur();
      };
      $("#ck").onclick=check;
      inp.onkeydown=e=>{ if(e.key==="Enter") check(); };
    }};
}

function stepDlg(st){
  const l=COURSE[st.ci].ls[st.li], items=lessonOf(st.ci,st.li);
  return {
    html:`<div class="eyebrow">Dialog</div><h1 style="margin-bottom:14px">${esc(l.t)}</h1>
      <div class="dlg">${items.map((i,n)=>`
        <div class="bubble ${l.dlg[n]&&l.dlg[n][0]==="B"?"b":""}">
          <div class="de">${esc(i.de)}</div><div class="say">${esc(i.tr)}</div>
          <div class="audio-row" style="justify-content:flex-start;margin-top:8px">
            <button class="icon" data-p="${i.id}">▶</button>
            <button class="icon" data-s="${i.id}">◐</button>
          </div></div>`).join("")}</div>
      <div class="btn-row" style="margin-top:16px"><button class="btn" id="go">Jetzt üben</button></div>`,
    wire(){
      $$("[data-p]").forEach(b=>b.onclick=()=>play(b.dataset.p));
      $$("[data-s]").forEach(b=>b.onclick=()=>play(b.dataset.s,.6));
      $("#go").onclick=nextStep;
    }};
}

