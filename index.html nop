<script>
/* ========================= Werkzeuge ========================= */
const $  = (s,r=document)=>r.querySelector(s);
const $$ = (s,r=document)=>[...r.querySelectorAll(s)];
const esc = s => String(s==null?"":s).replace(/[&<>"]/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;"}[c]));
const TEMPLATE = document.documentElement.outerHTML;   // sauberer Bauplan für den Export
const PACK = (typeof window!=="undefined" && window.__PACK__) || null;
const DAY = 864e5;
const today = () => new Date().toISOString().slice(0,10);
const norm = s => String(s).toLowerCase().replace(/['’\-\s.,!?]/g,"");

/* ========================= Speicher ========================= */
const DB = (()=>{
  let p;
  const open = () => p || (p = new Promise((res,rej)=>{
    const r = indexedDB.open("annetti-assyrisch",1);
    r.onupgradeneeded = () => {
      const db=r.result;
      ["audio","mine","meta"].forEach(s=>{ if(!db.objectStoreNames.contains(s)) db.createObjectStore(s); });
    };
    r.onsuccess=()=>res(r.result); r.onerror=()=>rej(r.error);
  }));
  const tx = async (store,mode,fn)=>{
    const db = await open();
    return new Promise((res,rej)=>{
      const t=db.transaction(store,mode), req=fn(t.objectStore(store));
      t.oncomplete=()=>res(req&&req.result); t.onerror=()=>rej(t.error);
    });
  };
  return {
    get:(s,k)=>tx(s,"readonly",st=>st.get(k)),
    set:(s,k,v)=>tx(s,"readwrite",st=>st.put(v,k)),
    del:(s,k)=>tx(s,"readwrite",st=>st.delete(k)),
    keys:s=>tx(s,"readonly",st=>st.getAllKeys())
  };
})();

/* ========================= Zustand ========================= */
const S = {
  view:"heute", xp:0, streak:0, lastDay:"", xpToday:0, goal:50,
  done:{}, srs:{}, fav:{}, hard:{},
  edits:{}, custom:[], del:{},
  have:new Set(), mine:new Set(),
  admin:false, notice:"", playing:null, recId:null, recStore:"audio",
  search:"", listCh:0, sheet:null
};
let RUN=null, mediaRecorder=null, saveTimer=null;
const urlCache={};

function plain(){
  return {xp:S.xp,streak:S.streak,lastDay:S.lastDay,xpToday:S.xpToday,goal:S.goal,
    done:S.done,srs:S.srs,fav:S.fav,hard:S.hard,edits:S.edits,custom:S.custom,del:S.del};
}
function save(){
  clearTimeout(saveTimer);
  saveTimer = setTimeout(()=>DB.set("meta","state",plain()).catch(()=>{}),250);
}

/* ========================= Wortbestand ========================= */
let ITEMS=[], BYID={};
function buildItems(){
  const out=[];
  COURSE.forEach((ch,ci)=>ch.ls.forEach((ls,li)=>{
    const arr = ls.w||ls.s;
    if(arr) arr.forEach((p,ii)=>out.push({id:`${ci+1}.${li+1}.${ii+1}`,de:p[0],tr:p[1],kind:ls.w?"w":"s",ci,li}));
    if(ls.dlg) ls.dlg.forEach((p,ii)=>out.push({id:`${ci+1}.${li+1}.${ii+1}`,de:p[1],tr:p[2],who:p[0],kind:"d",ci,li}));
  }));
  S.custom.forEach(c=>out.push({...c,custom:1}));
  ITEMS = out.filter(i=>!S.del[i.id]).map(i=> S.edits[i.id] ? {...i,...S.edits[i.id]} : i);
  BYID={}; ITEMS.forEach(i=>BYID[i.id]=i);
}
const lessonOf = (ci,li) => ITEMS.filter(i=>i.ci===ci&&i.li===li);
const lessonKey = (ci,li) => ci+"."+li;
function lessonMeta(ci,li){ const l=COURSE[ci].ls[li]; return {...l, items:lessonOf(ci,li)}; }
function allLessons(){
  const out=[]; COURSE.forEach((ch,ci)=>ch.ls.forEach((l,li)=>out.push({ci,li,l}))); return out;
}
function nextLesson(){
  const a=allLessons().find(x=>!S.done[lessonKey(x.ci,x.li)]);
  return a || allLessons()[allLessons().length-1];
}
function seenItems(){ return ITEMS.filter(i=>S.srs[i.id]); }
function dueItems(){ const n=Date.now(); return seenItems().filter(i=>S.srs[i.id].due<=n); }

/* ========================= Wiederholungssystem ========================= */
const IVL=[36e5, DAY, 3*DAY, 7*DAY, 14*DAY, 30*DAY, 90*DAY];
function grade(id, ok){
  const r = S.srs[id] || {b:0,due:0,w:0};
  if(ok){ r.b=Math.min(r.b+1,IVL.length-1); r.w=Math.max(0,r.w-1); }
  else   { r.b=0; r.w=Math.min(r.w+1,6); }
  r.due = Date.now() + Math.round(IVL[r.b]/(1+r.w*0.6));
  S.srs[id]=r; save();
}
function touch(id){ if(!S.srs[id]){ S.srs[id]={b:0,due:Date.now()+36e5,w:0}; save(); } }

function addXP(n){
  const t=today();
  if(S.lastDay!==t){
    S.streak = (S.lastDay && (new Date(t)-new Date(S.lastDay))<=DAY*1.5) ? S.streak+1 : 1;
    S.lastDay=t; S.xpToday=0;
  }
  S.xp+=n; S.xpToday+=n; save(); paintHead();
}
function paintHead(){
  $("#hd-streak").innerHTML = `🔥 <span class="v">${S.streak}</span>`;
  $("#hd-xp").textContent = S.xp+" XP";
}

/* ========================= Ton ========================= */
async function audioUrl(id, store="audio"){
  const key = store+":"+id;
  if(urlCache[key]) return urlCache[key];
  let blob=null;
  try{ blob = await DB.get(store,id); }catch(e){}
  if(blob) return (urlCache[key] = URL.createObjectURL(blob));
  if(store==="audio" && PACK && PACK.audio && PACK.audio[id]) return (urlCache[key]=PACK.audio[id]);
  return null;
}
async function play(id, rate=1, store="audio"){
  const url = await audioUrl(id,store);
  if(!url){ toast("Für dieses Wort gibt es noch keine Aufnahme."); return; }
  const a = new Audio(url); a.playbackRate = rate;
  S.playing=id; if(!RUN) repaint();
  a.onended = a.onerror = ()=>{ S.playing=null; if(!RUN) repaint(); };
  a.play().catch(()=>{ S.playing=null; if(!RUN) repaint(); });
}
async function startRec(id, store="audio"){
  if(S.recId) return stopRec();
  try{
    const stream = await navigator.mediaDevices.getUserMedia({audio:true});
    mediaRecorder = new MediaRecorder(stream);
    const chunks=[];
    mediaRecorder.ondataavailable = e => e.data.size && chunks.push(e.data);
    mediaRecorder.onstop = async ()=>{
      stream.getTracks().forEach(t=>t.stop());
      const blob = new Blob(chunks,{type: mediaRecorder.mimeType || "audio/webm"});
      try{
        await DB.set(store,id,blob);
        const key=store+":"+id;
        if(urlCache[key]){ URL.revokeObjectURL(urlCache[key]); delete urlCache[key]; }
        (store==="audio"?S.have:S.mine).add(id);
      }catch(e){ toast("Aufnahme konnte nicht gespeichert werden."); }
      S.recId=null; repaint();
    };
    mediaRecorder.start();
    S.recId=id; S.recStore=store; repaint();
  }catch(err){
    S.recId=null;
    toast(err && err.name==="NotAllowedError"
      ? "Mikrofon wurde abgelehnt. Im Browser oben auf das Schloss tippen und Mikrofon erlauben."
      : "Kein Mikrofon verfügbar ("+(err&&err.name)+").");
    repaint();
  }
}
function stopRec(){ mediaRecorder && mediaRecorder.state!=="inactive" && mediaRecorder.stop(); }
async function delRec(id, store="audio"){
  await DB.del(store,id);
  const key=store+":"+id;
  if(urlCache[key]){ URL.revokeObjectURL(urlCache[key]); delete urlCache[key]; }
  (store==="audio"?S.have:S.mine).delete(id); repaint();
}

let toastTimer=null;
function toast(msg){
  S.notice=msg; clearTimeout(toastTimer);
  toastTimer=setTimeout(()=>{S.notice=""; if(!RUN) repaint();},4200);
  if(!RUN) repaint();
}

/* ========================= Start ========================= */
async function boot(){
  try{
    const st = await DB.get("meta","state");
    if(st) Object.assign(S,{
      xp:st.xp||0, streak:st.streak||0, lastDay:st.lastDay||"", xpToday:st.xpToday||0,
      goal:st.goal||50, done:st.done||{}, srs:st.srs||{}, fav:st.fav||{}, hard:st.hard||{},
      edits:st.edits||{}, custom:st.custom||[], del:st.del||{}
    });
    S.have = new Set(await DB.keys("audio") || []);
    S.mine = new Set(await DB.keys("mine") || []);
  }catch(e){
    S.notice="Der Browser blockiert den lokalen Speicher. Im privaten Modus lässt sich nichts sichern.";
  }
  /* Beigelegte Aufnahmen und Ergänzungen dazunehmen, nichts überschreiben */
  if(PACK){
    Object.keys(PACK.audio||{}).forEach(id=>S.have.add(id));
    Object.entries(PACK.edits||{}).forEach(([id,v])=>{ if(!S.edits[id]) S.edits[id]=v; });
    const known=new Set(S.custom.map(c=>c.id));
    (PACK.custom||[]).forEach(c=>{ if(!known.has(c.id)) S.custom.push(c); });
  }
  if(S.lastDay && S.lastDay!==today()){
    const gap = (new Date(today()) - new Date(S.lastDay))/DAY;
    if(gap>1.5) S.streak=0;
    S.xpToday=0;
  }
  buildItems(); paintHead(); paintTabs();
  if(!window.isSecureContext) S.notice =
    "Aufnehmen geht in diesem Browser nur über eine sichere Verbindung. Öffne die Datei mit Firefox oder lege sie auf einen Webserver.";
  repaint();
}

