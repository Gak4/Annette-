<!doctype html>
<html lang="de"><head><meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
<meta name="theme-color" content="#0A0A0B">
<title>Annetti Vannetti lernt Assyrisch</title>
<style>
:root{
  --bg:#0A0A0B; --panel:#141416; --panel2:#1B1B1E; --line:#2A2A2F;
  --ink:#F3F1ED; --muted:#8B8B92; --gold:#E0B355; --gold-dim:#7A6230;
  --blue:#3C6FB4; --red:#C0433F; --green:#4E9A6A;
  --sans:ui-sans-serif,system-ui,-apple-system,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
  --mono:ui-monospace,SFMono-Regular,Menlo,Consolas,"Roboto Mono",monospace;
  --tap:44px;
}
*{box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html,body{height:100%}
body{margin:0;background:var(--bg);color:var(--ink);font-family:var(--sans);
  font-size:16px;line-height:1.45;-webkit-font-smoothing:antialiased;
  padding-bottom:calc(64px + env(safe-area-inset-bottom))}
button,input,select{font-family:inherit;font-size:inherit;color:inherit}
button{cursor:pointer;border:none;background:none}
:focus-visible{outline:2px solid var(--gold);outline-offset:2px;border-radius:4px}

/* ---------- Kopf ---------- */
header{position:sticky;top:0;z-index:20;background:rgba(10,10,11,.92);
  backdrop-filter:blur(12px);border-bottom:1px solid var(--line)}
.hd{max-width:640px;margin:0 auto;padding:12px 18px calc(12px + env(safe-area-inset-top)) 18px;
  display:flex;align-items:center;justify-content:space-between;gap:12px}
.mark{font-size:15px;font-weight:700;letter-spacing:-.02em;line-height:1.15}
.mark b{display:block;font-size:10px;font-weight:500;letter-spacing:.22em;
  text-transform:uppercase;color:var(--gold);font-family:var(--mono)}
.hd-right{display:flex;align-items:center;gap:14px;font-family:var(--mono);font-size:12px;color:var(--muted)}
.hd-right .v{color:var(--ink)}
.lockbtn{width:34px;height:34px;border:1px solid var(--line);border-radius:8px;color:var(--muted);
  display:grid;place-items:center;font-size:14px}

main{max-width:640px;margin:0 auto;padding:20px 18px 40px}

/* ---------- Bausteine ---------- */
.eyebrow{font-family:var(--mono);font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted)}
h1{font-size:26px;line-height:1.15;letter-spacing:-.03em;margin:6px 0 18px;font-weight:700}
h2{font-size:15px;margin:26px 0 10px;font-weight:600;letter-spacing:-.01em}
p{margin:0 0 12px}
.sub{color:var(--muted);font-size:14px}
.panel{background:var(--panel);border:1px solid var(--line);border-radius:14px;padding:16px}
.panel+.panel{margin-top:10px}
.row{display:flex;align-items:center;gap:12px}
.spread{display:flex;align-items:center;justify-content:space-between;gap:12px}
.tr{font-family:var(--mono);color:var(--gold)}
.mut{color:var(--muted)}
.hide{display:none!important}

.btn{display:block;width:100%;min-height:var(--tap);background:var(--gold);color:#17140C;
  border-radius:12px;padding:13px 18px;font-weight:700;font-size:16px;letter-spacing:-.01em;text-align:center}
.btn:active{transform:translateY(1px)}
.btn[disabled]{background:var(--panel2);color:var(--muted);cursor:not-allowed;transform:none}
.btn.ghost{background:none;border:1px solid var(--line);color:var(--ink);font-weight:600}
.btn.quiet{background:none;color:var(--muted);font-weight:500;font-size:14px;min-height:0;padding:10px}
.btn.danger{background:none;border:1px solid var(--red);color:var(--red);font-weight:600}
.btn-row{display:flex;gap:10px;margin-top:10px}
.btn-row .btn{flex:1}
.chip{min-height:38px;border:1px solid var(--line);border-radius:999px;padding:8px 14px;
  font-size:13px;color:var(--muted);white-space:nowrap;background:var(--panel)}
.chip.on{background:var(--ink);border-color:var(--ink);color:var(--bg);font-weight:600}
.scroller{display:flex;gap:8px;overflow-x:auto;padding-bottom:4px;margin:0 -18px 14px;padding-left:18px;padding-right:18px;
  scrollbar-width:none}
.scroller::-webkit-scrollbar{display:none}

/* ---------- Heute ---------- */
.streak{display:flex;gap:10px;margin-bottom:14px}
.stat{flex:1;background:var(--panel);border:1px solid var(--line);border-radius:14px;padding:14px}
.stat .n{font-family:var(--mono);font-size:24px;font-weight:600;letter-spacing:-.02em;line-height:1}
.stat .l{font-size:11px;color:var(--muted);margin-top:6px;letter-spacing:.04em}
.bar{height:6px;background:var(--panel2);border-radius:99px;overflow:hidden;margin-top:12px}
.bar i{display:block;height:100%;background:var(--gold);border-radius:99px;transition:width .5s ease}
.bar.blue i{background:var(--blue)}

/* ---------- Kurspfad ---------- */
.chapter{margin-bottom:22px}
.ch-head{display:flex;align-items:baseline;gap:10px;margin-bottom:10px}
.ch-num{font-family:var(--mono);font-size:11px;color:var(--gold-dim)}
.ch-title{font-weight:650;font-size:15px;letter-spacing:-.01em}
.path{position:relative;padding-left:26px}
.path:before{content:"";position:absolute;left:7px;top:12px;bottom:12px;width:1px;background:var(--line)}
.node{position:relative;display:flex;align-items:center;gap:12px;width:100%;text-align:left;
  padding:12px 14px;margin-bottom:8px;background:var(--panel);border:1px solid var(--line);border-radius:12px;min-height:var(--tap)}
.node:before{content:"";position:absolute;left:-23px;top:50%;transform:translateY(-50%);
  width:9px;height:9px;border-radius:99px;background:var(--bg);border:1px solid var(--line)}
.node.done:before{background:var(--gold);border-color:var(--gold)}
.node.next{border-color:var(--gold)}
.node.next:before{border-color:var(--gold)}
.node .t{flex:1;font-size:14px;font-weight:550}
.node .m{font-family:var(--mono);font-size:11px;color:var(--muted)}
.node.locked{opacity:.45}

/* ---------- Lernkarte ---------- */
.stage{background:var(--panel);border:1px solid var(--line);border-radius:16px;
  padding:30px 20px;text-align:center;min-height:260px;display:flex;flex-direction:column;
  justify-content:center;gap:18px;animation:pop .25s ease both}
@keyframes pop{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
.stage .de{font-size:27px;font-weight:700;letter-spacing:-.025em;line-height:1.2}
.stage .say{font-family:var(--mono);font-size:31px;color:var(--gold);letter-spacing:-.01em;
  line-height:1.25;word-break:break-word}
.stage .say.sm{font-size:22px}
.stage .hint{font-size:13px;color:var(--muted)}
.audio-row{display:flex;gap:8px;justify-content:center;flex-wrap:wrap}
.abtn{min-height:var(--tap);border:1px solid var(--line);border-radius:11px;padding:11px 16px;
  font-size:14px;color:var(--ink);background:var(--panel2);display:inline-flex;align-items:center;gap:7px}
.abtn.live{background:var(--red);border-color:var(--red);color:#fff}
.abtn[disabled]{opacity:.35;cursor:not-allowed}
.progress-top{display:flex;align-items:center;gap:12px;margin-bottom:16px}
.progress-top .bar{flex:1;margin:0}
.x{width:34px;height:34px;border:1px solid var(--line);border-radius:9px;color:var(--muted);flex:0 0 auto}

/* ---------- Quiz ---------- */
.opts{display:grid;gap:8px;margin-top:16px}
.opt{min-height:var(--tap);text-align:left;padding:14px 16px;background:var(--panel);
  border:1px solid var(--line);border-radius:12px;font-size:15px;display:flex;justify-content:space-between;gap:10px}
.opt .k{font-family:var(--mono);color:var(--gold)}
.opt.right{border-color:var(--green);background:rgba(78,154,106,.12)}
.opt.wrong{border-color:var(--red);background:rgba(192,67,63,.12)}
.opt[disabled]{cursor:default}
.answer{width:100%;min-height:var(--tap);background:var(--panel);border:1px solid var(--line);
  border-radius:12px;padding:13px 15px;font-family:var(--mono);font-size:17px;color:var(--gold)}
.verdict{margin-top:14px;padding:14px 16px;border-radius:12px;font-size:14px}
.verdict.ok{background:rgba(78,154,106,.12);border:1px solid var(--green)}
.verdict.no{background:rgba(192,67,63,.12);border:1px solid var(--red)}
.verdict b{font-family:var(--mono);color:var(--gold);font-weight:400}

/* ---------- Listen ---------- */
.item{display:flex;align-items:center;gap:12px;padding:13px 14px;border-bottom:1px solid var(--line)}
.item:last-child{border-bottom:none}
.item .txt{flex:1;min-width:0}
.item .de{font-size:14.5px;font-weight:550}
.item .say{font-family:var(--mono);font-size:13px;color:var(--gold);margin-top:2px;word-break:break-word}
.icon{width:38px;height:38px;flex:0 0 auto;border:1px solid var(--line);border-radius:9px;
  color:var(--muted);display:grid;place-items:center;font-size:13px;background:var(--panel2)}
.icon.on{color:var(--gold);border-color:var(--gold-dim)}
.icon.rec{background:var(--red);border-color:var(--red);color:#fff}
.list{background:var(--panel);border:1px solid var(--line);border-radius:14px;overflow:hidden}
.dot{width:6px;height:6px;border-radius:99px;background:var(--line);flex:0 0 auto}
.dot.on{background:var(--gold)}

.field{width:100%;min-height:var(--tap);background:var(--panel2);border:1px solid var(--line);
  border-radius:10px;padding:12px 14px;font-size:15px;margin-bottom:8px}
.field.mono{font-family:var(--mono);color:var(--gold)}
label.lb{display:block;font-size:12px;color:var(--muted);margin:10px 0 5px}

.dlg{display:flex;flex-direction:column;gap:10px}
.bubble{max-width:86%;padding:12px 14px;border-radius:14px;background:var(--panel2);border:1px solid var(--line)}
.bubble.b{align-self:flex-end;background:rgba(224,179,85,.09);border-color:var(--gold-dim)}
.bubble .de{font-size:14.5px}
.bubble .say{font-family:var(--mono);font-size:13.5px;color:var(--gold);margin-top:3px}

.note{border:1px solid var(--gold-dim);background:rgba(224,179,85,.07);border-radius:12px;
  padding:12px 14px;font-size:13px;line-height:1.5;margin-bottom:14px;color:#E8DFCB}
.note.warn{border-color:var(--red);background:rgba(192,67,63,.08);color:#F0D2D1}

.badge{display:inline-flex;align-items:center;gap:6px;border:1px solid var(--line);border-radius:99px;
  padding:6px 11px;font-size:12px;color:var(--muted);font-family:var(--mono)}
.badge.on{border-color:var(--gold-dim);color:var(--gold)}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:8px}

/* ---------- Tableiste ---------- */
.tabs{position:fixed;left:0;right:0;bottom:0;z-index:20;background:rgba(10,10,11,.94);
  backdrop-filter:blur(12px);border-top:1px solid var(--line);
  padding-bottom:env(safe-area-inset-bottom)}
.tabs-in{max-width:640px;margin:0 auto;display:flex}
.tab{flex:1;min-height:56px;display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:3px;color:var(--muted);font-size:10.5px;letter-spacing:.03em}
.tab .g{font-size:16px;line-height:1}
.tab.on{color:var(--gold)}
.tab.on .g{transform:translateY(-1px)}

.sheet{position:fixed;inset:0;z-index:40;background:rgba(6,6,7,.75);display:flex;align-items:flex-end}
.sheet-in{width:100%;max-width:640px;margin:0 auto;background:var(--panel);
  border-top-left-radius:18px;border-top-right-radius:18px;border:1px solid var(--line);
  padding:20px 18px calc(24px + env(safe-area-inset-bottom));max-height:88vh;overflow:auto;
  animation:up .22s ease both}
@keyframes up{from{transform:translateY(14px);opacity:0}to{transform:none;opacity:1}}

@media (prefers-reduced-motion:reduce){*{animation:none!important;transition:none!important}}
@media(min-width:560px){h1{font-size:30px}.stage .de{font-size:31px}.stage .say{font-size:36px}}
</style>
</head><body>
<header><div class="hd">
  <div class="mark"><b>Deutsch → Assyrisch</b>Annetti Vannetti lernt Assyrisch</div>
  <div class="hd-right">
    <span id="hd-streak">🔥 <span class="v">0</span></span>
    <span id="hd-xp" class="v">0 XP</span>
    <button class="lockbtn" id="lockbtn" aria-label="Adminbereich">⚙</button>
  </div>
</div></header>
<main id="app"></main>
<nav class="tabs"><div class="tabs-in" id="tabs"></div></nav>
<div id="sheet"></div>
