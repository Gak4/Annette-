    ["meine Mutter","yimmi"],["mein Vater","babi"]]},
  {t:"Geschwister und Kinder", w:[
    ["der Bruder","akhona"],["die Schwester","khatha"],["der Sohn","brona"],
    ["die Tochter","brata"],["das Kind","yala"],["die Kinder","yale"]]},
  {t:"Oma, Opa, Verwandte", w:[
