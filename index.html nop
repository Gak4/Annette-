    <button class="btn quiet" id="out" style="margin-top:20px">Adminbereich verlassen</button>`;

  $("#aq").oninput = e => { S.search=e.target.value; const p=e.target.selectionStart; repaint(); const n=$("#aq"); n.focus(); n.setSelectionRange(p,p); };
  $("#n-add").onclick = ()=>{
    const de=$("#n-de").value.trim(), tr=$("#n-tr").value.trim();
    if(!de||!tr) return toast("Deutsch und Aussprache ausfüllen.");
    const [ci,li]=$("#n-l").value.split(".").map(Number);
    S.custom.push({id:"u"+Date.now().toString(36),de,tr,kind:de.split(" ").length>2?"s":"w",ci,li});
    save(); buildItems(); toast("Hinzugefügt."); repaint();
  };
  $$("[data-p]").forEach(b=>b.onclick=()=>play(b.dataset.p));
  $$("[data-r]").forEach(b=>b.onclick=()=>S.recId?stopRec():startRec(b.dataset.r,"audio"));
  $$("[data-e]").forEach(b=>b.onclick=()=>editSheet(b.dataset.e));
  $("#x-app").onclick = exportApp;
  $("#x-json").onclick = exportPack;
