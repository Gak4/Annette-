function editSheet(id){
  const i=BYID[id]; if(!i) return;
  $("#sheet").innerHTML = `<div class="sheet"><div class="sheet-in">
    <div class="eyebrow">Eintrag bearbeiten</div>
    <label class="lb">Deutsch</label><input class="field" id="e-de" value="${esc(i.de)}">
    <label class="lb">Assyrische Aussprache</label><input class="field mono" id="e-tr" value="${esc(i.tr)}">
    <button class="btn" id="e-save">Speichern</button>
    <div class="btn-row">
      <button class="btn ghost" id="e-rec">${S.have.has(id)?"Neu aufnehmen":"Aufnehmen"}</button>
      <button class="btn ghost" id="e-play" ${S.have.has(id)?"":"disabled"}>Anhören</button>
    </div>
    ${S.have.has(id)?`<button class="btn quiet" id="e-delrec">Aufnahme löschen</button>`:""}
    <button class="btn danger" id="e-del" style="margin-top:10px">Eintrag löschen</button>
    <button class="btn quiet" id="e-x">Schließen</button>
  </div></div>`;
  const close=()=>{ $("#sheet").innerHTML=""; repaint(); };
  $("#e-x").onclick=close;
  $("#e-save").onclick=()=>{
    const de=$("#e-de").value.trim(), tr=$("#e-tr").value.trim();
    if(i.custom){ const c=S.custom.find(c=>c.id===id); if(c){c.de=de;c.tr=tr;} }
    else S.edits[id]={de,tr};
    save(); buildItems(); close();
  };
  $("#e-rec").onclick=()=>{ S.recId?stopRec():startRec(id,"audio"); toast(S.recId?"Aufnahme läuft — nochmal tippen zum Stoppen.":"Aufnahme gestartet."); };
  $("#e-play").onclick=()=>play(id);
  const dr=$("#e-delrec"); if(dr) dr.onclick=()=>{ delRec(id); close(); };
  $("#e-del").onclick=()=>{
    if(i.custom) S.custom=S.custom.filter(c=>c.id!==id); else S.del[id]=1;
    save(); buildItems(); close();
  };
}

/* ========================= Sichern / Übertragen ========================= */
async function buildPack(){
  const pack={v:2,edits:S.edits,custom:S.custom,del:S.del,audio:{}};
  for(const id of S.have){
    let blob=null;
    try{ blob=await DB.get("audio",id); }catch(e){}
    if(blob) pack.audio[id]=await new Promise(r=>{const fr=new FileReader();fr.onload=()=>r(fr.result);fr.readAsDataURL(blob);});
    else if(PACK && PACK.audio && PACK.audio[id]) pack.audio[id]=PACK.audio[id];
  }
  return pack;
}
function download(blob,name){
  const a=document.createElement("a");
  a.href=URL.createObjectURL(blob); a.download=name; a.click();
  setTimeout(()=>URL.revokeObjectURL(a.href),4000);
}
async function exportApp(){
  toast("Datei wird gebaut …");
  const pack=await buildPack();
  const tag='<scr'+'ipt id="pack">window.__PACK__='+JSON.stringify(pack).replace(/</g,"\\u003c")+'</scr'+'ipt>';
  let html = TEMPLATE.replace(/<script id="pack">[\s\S]*?<\/script>/,"<!--PACK-->");
  html = html.includes("<!--PACK-->") ? html.replace("<!--PACK-->",tag) : html.replace("</head>",tag+"</head>");
  download(new Blob(["<!doctype html>\n"+html],{type:"text/html"}),"annetti-lernt-assyrisch.html");
  toast("Fertig. Diese Datei kann sie direkt öffnen.");
}
async function exportPack(){
  const pack=await buildPack();
  download(new Blob([JSON.stringify(pack)],{type:"application/json"}),"assyrisch-daten.json");
}
async function importPack(file){
  try{
    const pack=JSON.parse(await file.text());
    S.edits={...S.edits,...(pack.edits||{})};
    S.del={...S.del,...(pack.del||{})};
    const known=new Set(S.custom.map(c=>c.id));
    (pack.custom||[]).forEach(c=>{ if(!known.has(c.id)) S.custom.push(c); });
    for(const [id,dataUrl] of Object.entries(pack.audio||{})){
      const blob=await (await fetch(dataUrl)).blob();
      await DB.set("audio",id,blob);
      const k="audio:"+id;
      if(urlCache[k]){ URL.revokeObjectURL(urlCache[k]); delete urlCache[k]; }
      S.have.add(id);
    }
    save(); buildItems(); toast("Daten übernommen.");
  }catch(e){ toast("Die Datei konnte nicht gelesen werden."); }
  repaint();
}

/* ========================= Tastatur ========================= */
document.addEventListener("keydown",e=>{
  if(!RUN || e.target.tagName==="INPUT") return;
  if(e.key==="Enter"){ const b=$("#next")||$("#ok")||$("#go"); if(b) b.click(); }
  if(e.key>="1"&&e.key<="4"){ const o=$$("[data-o]")[+e.key-1]; if(o) o.click(); }
});

boot();
